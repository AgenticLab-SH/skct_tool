{
  "manifest_version": 3,
  "name": "SKCT Tool - 링커리어 Focus Bypass",
  "version": "1.0.0",
  "description": "링커리어 CBT 등 외부 모의고사 사이트의 포커스 감지를 자동 우회하여 SKCT Tool과 함께 사용할 수 있게 합니다.",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "https://cbt.linkareer.com/*",
        "https://skct.agenticfabworks.com/*",
        "http://127.0.0.1:*/*",
        "http://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
